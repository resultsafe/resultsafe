{
  "files.exclude": {
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": false,
    "**/*.log": false,
    "**/coverage": false,
    "**/.git": true,
    "**/.env": false,
    "**/build": false
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/*.min.js": false,
    "**/coverage": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/dist/**": false,
    "**/*.tmp": false
  }
}
