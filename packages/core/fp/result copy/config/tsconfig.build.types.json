{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../src",
    "baseUrl": "..",
    "paths": {
      "@resultsafe/core-fp-option": [
        "node_modules/@resultsafe/core-fp-option/dist/types/index.d.ts"
      ],
      "@resultsafe/core-fp-option-shared": [
        "node_modules/@resultsafe/core-fp-option-shared/dist/types/index.d.ts"
      ],
      "@resultsafe/core-fp-result-shared": [
        "node_modules/@resultsafe/core-fp-result-shared/dist/types/index.d.ts"
      ],
      "@resultsafe/core-fp-union": [
        "node_modules/@resultsafe/core-fp-union/dist/types/index.d.ts"
      ]
    },
    "outDir": "../dist/types",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "sourceMap": false,
    "inlineSourceMap": false,
    "noEmit": false,
    "removeComments": false,
    "stripInternal": false,
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "../.tsbuildinfo"
  },
  "include": ["../src"]
}


