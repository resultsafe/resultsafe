{
  "extends": "../../../../tsconfig.aliases.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "tsBuildInfoFile": "./.tsbuildinfo",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": true
  },
  "include": [
    "src/**/*.ts",
    "config/**/*.ts",
    "__examples__/**/*.ts",
    "__tests__/**/*.ts",
    "__scripts__/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}

