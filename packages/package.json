{
  "name": "@resultsafe/monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/core/fp/result",
    "packages/core/fp/result-shared",
    "packages/core/fp/shared",
    "packages/core/fp/union",
    "packages/core/fp/option",
    "packages/core/fp/option-shared",
    "packages/core/fp/either",
    "packages/core/fp/void",
    "packages/core/fp/task",
    "packages/core/fp/task-result",
    "packages/core/fp/effect",
    "packages/core/fp/pipe",
    "packages/core/fp/flow",
    "packages/core/fp/do",
    "packages/core/fp/layer",
    "packages/core/fp/context",
    "packages/core/fp/codec",
    "packages/adapter/core/fp/codec/zod"
  ],
  "type": "module",
  "description": "",
  "scripts": {
    "pkg:playground:run": "pnpm -C ./playground run run",
    "pkg:playground:dev": "pnpm -C ./playground run dev",
    "pkg:result:clean": "pnpm -C ./core/fp/result run clean:dist",
    "pkg:result:build": "pnpm -C ./core/fp/result run build:all",
    "pkg:result:test": "pnpm -C ./core/fp/result run test",
    "pkg:result:lint": "pnpm -C ./core/fp/result run lint",
    "pkg:result:docs:api": "pnpm -C ./core/fp/result run docs:api",
    "pkg:result:verify": "pnpm -C ./core/fp/result run verify:release",
    "lint": "eslint ./src ./__tests__ --config ./config/eslint.config.mjs --ext .ts",
    "clean:dist": "cmd /c  rimraf dist",
    "clean:dist:esm": "rimraf dist/esm",
    "clean:dist:cjs": "rimraf dist/cjs",
    "clean:dist:esm-cjs": "pnpm run clean:dist:esm && pnpm run clean:dist:cjs",
    "readme:create": "pnpx tsx __scripts__/create-readme.ts",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest",
    "build": "pnpm run clean:dist:esm-cjs && vite build --config ./config/vite.config.ts",
    "build:tsc:types": "pnpm run clean:dist:esm-cjs && tsc -p ./config/tsconfig.build.tsc.types.json",
    "docs:html": "pnpm typedoc --options ./config/typedoc-html.json",
    "docs:md": "pnpm typedoc --options ./config/typedoc-md.json",
    "docs:docusaurus": "pnpm typedoc --options ./config/typedoc-docusaurus.json",
    "docs": "pnpm run docs:html && pnpm run docs:md"
  },
  "packageManager": "pnpm@10.15.0",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@docusaurus/types": "^3.8.1",
    "@types/node": "^24.4.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^16.1.6",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.50.2",
    "rollup-plugin-cleanup": "^3.2.1",
    "terser": "^5.44.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "ts-node-esm": "^0.0.6",
    "tsconfig-paths": "^4.2.0",
    "tsd": "^0.33.0",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.8.1",
    "typedoc-plugin-mdn-links": "^5.0.9",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@docusaurus/preset-classic": "^3.8.1",
    "strip-json-comments": "^5.0.3",
    "zod": "^3.25.76"
  }
}

