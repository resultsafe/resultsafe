{
  "name": "@resultsafe/monorepo-root",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "playground:result": "pnpm -C packages/playground run run",
    "playground:result:dev": "pnpm -C packages/playground run dev",
    "pkg:result:clean": "pnpm -C packages/core/fp/result run clean:dist",
    "pkg:result:build": "pnpm -C packages/core/fp/result run build:all",
    "pkg:result:test": "pnpm -C packages/core/fp/result run test",
    "pkg:result:lint": "pnpm -C packages/core/fp/result run lint",
    "pkg:result:docs:api": "pnpm -C packages/core/fp/result run docs:api",
    "pkg:result:verify": "pnpm -C packages/core/fp/result run verify:release",
    "artifacts:generate": "tsx tools/artifacts/generate.ts",
    "artifacts:clean": "rimraf artifacts/generated artifacts/platforms artifacts/languages artifacts/formats artifacts/versions",
    "artifacts:validate": "tsx tools/artifacts/validate.ts",
    "artifacts:web:docusaurus": "tsx tools/artifacts/platforms/web/docusaurus.ts",
    "artifacts:ai:notebooklm": "tsx tools/artifacts/platforms/ai/notebooklm.ts",
    "artifacts:lang:en": "tsx tools/artifacts/languages.ts --lang en",
    "artifacts:lang:ru": "tsx tools/artifacts/languages.ts --lang ru",
    "changeset:add": "changeset add",
    "changeset:add:result": "node ./tools/release/create-changeset.mjs --package @resultsafe/core-fp-result",
    "changeset:status": "changeset status",
    "changeset:check": "node ./tools/release/changeset-check.mjs",
    "changeset:require-for-api": "node ./tools/release/check-api-change-requires-changeset.mjs",
    "version:prepare": "changeset version && pnpm install --lockfile-only",
    "release:verify": "pnpm run pkg:result:verify",
    "release:guard:result": "node ./tools/release/check-allowlist.mjs @resultsafe/core-fp-result",
    "release:ci": "pnpm run changeset:check && pnpm run changeset:require-for-api && pnpm run release:verify",
    "release:publish": "pnpm run release:guard:result && changeset publish",
    "release:publish:result": "pnpm run release:guard:result && pnpm run version:prepare && changeset publish"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "comment-parser": "^1.4.5"
  }
}
